generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

enum PlanName {
  free
  basic
  ai
}

enum ScanStatus {
  pending
  running
  completed
  failed
}

enum IssueSeverity {
  critical
  warning
  info
}

enum IssueType {
  missing_title
  weak_title
  missing_description
  short_description
  no_images
  missing_alt_text
  missing_seo_title
  missing_seo_description
  short_seo_description
  missing_category
  missing_product_type
  no_tags
  missing_barcode
  missing_vendor
}

model Shop {
  id            String   @id @default(cuid())
  domain        String   @unique
  plan          PlanName @default(free)
  language      String   @default("en")
  billingId     String?
  installedAt   DateTime @default(now())
  lastScanAt    DateTime?
  totalFixes    Int      @default(0)
  totalScans    Int      @default(0)
  altTextTemplate String?
  scans         Scan[]
  scanSnapshots ScanSnapshot[]
}

model ScanSnapshot {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  score     Float
  products  Int
  issues    Int
  createdAt DateTime @default(now())

  @@index([shopId])
}

model Scan {
  id              String        @id @default(cuid())
  shopId          String
  shop            Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  status          ScanStatus    @default(pending)
  bulkOperationId String?
  totalProducts   Int           @default(0)
  scannedProducts Int           @default(0)
  overallScore    Float?
  startedAt       DateTime      @default(now())
  completedAt     DateTime?
  productScores   ProductScore[]

  @@index([shopId])
}

model ProductScore {
  id           String   @id @default(cuid())
  scanId       String
  scan         Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  productGid   String
  productTitle String
  score        Float
  maxScore     Float    @default(100)
  imageCount   Int      @default(0)
  issues       Issue[]
  createdAt    DateTime @default(now())

  @@index([scanId])
  @@index([productGid])
}

model Issue {
  id             String        @id @default(cuid())
  productScoreId String
  productScore   ProductScore  @relation(fields: [productScoreId], references: [id], onDelete: Cascade)
  type           IssueType
  severity       IssueSeverity
  field          String
  message        String
  aiFixable      Boolean       @default(false)
  fixedAt        DateTime?

  @@index([productScoreId])
}

model FixHistory {
  id          String   @id @default(cuid())
  shopDomain  String
  productGid  String
  field       String
  oldValue    String?
  newValue    String?
  fixType     String
  appliedAt   DateTime @default(now())
  rolledBack  Boolean  @default(false)

  @@index([shopDomain, productGid])
}
